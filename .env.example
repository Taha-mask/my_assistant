# Copy this file to .env and fill in real values.
#
# OpenWeatherMap API key (free tier, no credit card required):
# 1. Sign up at https://openweathermap.org/api
# 2. Verify your email
# 3. Generate a key under "API keys"
# 4. Paste it below
#
# If left blank, the weather tool will return a polite error and Jarvis
# will keep working normally for everything else.
OPENWEATHER_API_KEY=your_key_here

# Default city used when you ask "what's the weather" without naming a place.
DEFAULT_CITY=Cairo

# Ollama model used by Jarvis. Better hardware can use a larger model.
# Examples: llama3.1:8b-instruct, qwen2.5:7b-instruct
OLLAMA_MODEL=llama3.2:3b
